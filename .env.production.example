# Copier ce fichier vers .env.production et ajuster les valeurs
# Utilisé automatiquement par `npm run build`

# Base du CDN de données (optionnel : le défaut est dans le code, aucun .env requis)
# VITE_DATA_URL=https://storage.googleapis.com/homepedia-web/v1

# Score territoire : GeoJSON public sur le bucket homepedia-web (fetch direct).
# Laisser vide pour utiliser le défaut (storage.googleapis.com/homepedia-web/v1/score.geojson).
# VITE_SCORE_URL=
