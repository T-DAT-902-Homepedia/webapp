# Copier ce fichier vers .env.development et ajuster les valeurs
# Utilisé automatiquement par `npm run dev`

# Base URL de l'API. En dev, `/api` est relayé vers FastAPI (port 8000) par le proxy Vite.
VITE_API_URL=/api

# Score territoire : GeoJSON public sur le bucket homepedia-web (fetch direct).
# Laisser vide pour utiliser le défaut (storage.googleapis.com/homepedia-web/v1/score.geojson).
# VITE_SCORE_URL=
